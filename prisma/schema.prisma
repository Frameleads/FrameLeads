generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InboundSignal {
  id              String   @id @default(uuid())
  prospectName    String
  prospectContext String
  pipelineValue   Int
  dealStage       String
  rawEmail        String
  intentRisk      String
  intentType      String
  aiDraft         String
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  whopId    String   @unique
  email     String   @unique
  tier      String   @default("CORE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
